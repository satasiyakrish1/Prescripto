# Admin Panel Environment Variables
# Copy this file to .env and fill in your actual values

# Backend Connection
VITE_BACKEND_URL=http://localhost:4000

# Display Settings
VITE_CURRENCY=₹

# Razorpay Payment (use your key from Razorpay dashboard)
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id_here
VITE_RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# OpenWeather API (get from openweathermap.org)
VITE_OPENWEATHER_API_KEY=your_openweather_api_key_here

# Admin master password for profile updates and password reset
VITE_ADMIN_MASTER_PASSWORD=your_admin_master_password_here
