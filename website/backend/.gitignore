/node_modules

# Environment variables - NEVER commit real .env files
.env
.env.*
.env.local
.env.producation
.env.production
!.env.example
!.env.template

# Google Wallet & Service Account credentials
/config/google-wallet-key.json
/config/google-wallet-service-account.json
/config/recaptcha-service-account.json

# All service account JSONs (allow only .example and .template)
service-account.json
*service-account*.json
!*service-account*.json.example
!*service-account*.json.template

# SSL/TLS Certificates and Private Keys
/certs/*.pem
/certs/*.crt
/certs/*.key
*.pem
*.key
*.p12
*.pfx

# Upload directories (exclude uploaded files)
uploads/medical-files/*
!uploads/medical-files/.gitkeep